# Server port (optional)
PORT=3000

# OpenRouter API key for LLM-powered extraction and chat answers
# If omitted, the app still works using deterministic local fallback logic.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Slack Incoming Webhook URL for posting structured handoff summaries.
# Create one in Slack: App settings -> Incoming Webhooks -> Add New Webhook to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
